{
  "name": "cheinisch/markdown-editor",
  "description": "It's a simple Markdown editor (HTML/JS/CSS) packaged for easy embedding in PHP apps via Composer.",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "cheinisch\\MarkdownEditor\\": "src/"
    }
  },
  "require": {
    "php": ">=8.0",
    "composer-plugin-api": "^2.0"
  },
  "require-dev": {
    "composer/composer": "^2.0"
  },
  "scripts": {
    "post-install-cmd": "cheinisch\\MarkdownEditor\\Composer\\ScriptHandler::publishAssets",
    "post-update-cmd":  "cheinisch\\MarkdownEditor\\Composer\\ScriptHandler::publishAssets"
  },
  "extra": {
    "branch-alias": {
      "dev-main": "1.x-dev"
    },
    "markdown-editor": {
      "public-dir": "public/vendor/markdown-editor"
    }
  }
}